---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import DashboardMock from '../../components/DashboardMock.astro';
import { withBase } from '../../utils/url';
---
<BaseLayout title="Data Visualisation Portfolio | Akhil Arun Menon" description="Power BI, Excel, Python and SQL portfolio covering sales, HR, marketing and academic analytics.">
  <PageHero eyebrow="Data visualisation" title="Dashboards designed around decisions, not decoration" description="A developing portfolio of end-to-end case studies covering data preparation, modelling, measures, visual design, interpretation and action." />

  <section class="section">
    <div class="container split">
      <div>
        <p class="eyebrow">Portfolio approach</p>
        <h2>Show the complete analytical process</h2>
        <p class="lead">Every case study is structured to demonstrate how raw records become a reliable model and how the model becomes a decision-oriented dashboard.</p>
        <ol class="prose">
          <li>Business or academic problem definition</li>
          <li>Data inventory and quality assessment</li>
          <li>Transformation and relationship design</li>
          <li>Measure development and validation</li>
          <li>Dashboard layout and interaction design</li>
          <li>Insights, limitations and recommended actions</li>
        </ol>
        <p>Confidential information is replaced with simulated or open data. Dashboard samples are presented for viewing and interaction but are not offered as downloadable source files.</p>
      </div>
      <DashboardMock />
    </div>
  </section>

  <section class="section section-dark">
    <div class="container">
      <p class="eyebrow">Tools</p>
      <h2>Analytics and reporting capabilities</h2>
      <div class="grid grid-4" style="margin-top:2rem">
        <article class="feature-card"><div class="icon">P</div><h3>Power BI</h3><p>Power Query, data modelling, DAX, drill-through, bookmarks, tooltips and publish-ready report design.</p></article>
        <article class="feature-card"><div class="icon">E</div><h3>Excel</h3><p>Structured models, formulas, PivotTables, charts, validation, scenario views and management dashboards.</p></article>
        <article class="feature-card"><div class="icon">Py</div><h3>Python</h3><p>Data preparation, exploratory analysis and visualisation using pandas, NumPy and Matplotlib.</p></article>
        <article class="feature-card"><div class="icon">SQL</div><h3>SQL</h3><p>Data extraction, aggregation, joins, validation queries and reporting views for analytical models.</p></article>
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container project-header">
      <div>
        <span class="tag">Featured case study</span>
        <p class="eyebrow" style="margin-top:1.2rem">Sales analytics</p>
        <h2>Candy Sales Performance and Profitability</h2>
        <p class="lead">A multi-table Power BI case study covering executive performance, product margin, targets, geography and shipping analysis.</p>
        <div class="tag-list"><span class="tag">Power Query</span><span class="tag">Star Schema</span><span class="tag">DAX</span><span class="tag">Targets</span><span class="tag">Geospatial Analysis</span></div>
        <p style="margin-top:1.5rem"><a class="btn" href={withBase('/data-visualisation/candy-sales')}>Open full case study</a></p>
      </div>
      <div class="project-cover"><img src={withBase('/images/brand/og-default.jpg')} alt="Data visualisation case study cover" /></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Use cases</p>
      <h2>Four portfolio tracks</h2>
      <div class="grid grid-4" style="margin-top:2rem">
        <article class="feature-card"><h3>HR Analytics</h3><p>Headcount, attrition, recruitment, diversity, learning, attendance and workforce planning.</p></article>
        <article class="feature-card"><h3>Sales Analytics</h3><p>Revenue, margin, targets, products, customers, geography, forecasting and pipeline health.</p></article>
        <article class="feature-card"><h3>Marketing Analytics</h3><p>Campaign performance, conversion, channel efficiency, customer acquisition and engagement.</p></article>
        <article class="feature-card"><h3>Academic Analytics</h3><p>Learner progress, assessments, attendance, course readiness, faculty workload and programme operations.</p></article>
      </div>
      <p style="margin-top:2rem"><a class="btn btn-outline" href={withBase('/data-visualisation/dashboard-roadmap')}>View the 10-dashboard build roadmap</a></p>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <p class="eyebrow">Interactive reports</p>
      <h2>Embedded dashboard gallery</h2>
      <p class="lead">Published Power BI reports will appear here using public or securely shared embed links. The website already includes responsive containers for the reports.</p>
      <div class="grid grid-2" style="margin-top:2rem">
        <article class="dashboard-shell"><div class="dashboard-topbar"><strong>Sales performance</strong><span>Embed slot 01</span></div><div class="dashboard-body"><div class="notice"><strong>In development:</strong> the Power BI report will be embedded after publication.</div></div></article>
        <article class="dashboard-shell"><div class="dashboard-topbar"><strong>Academic programme health</strong><span>Embed slot 02</span></div><div class="dashboard-body"><div class="notice"><strong>Planned:</strong> simulated programme data will be used to protect institutional information.</div></div></article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container cta-band">
      <p class="eyebrow">Training and consulting</p>
      <h2>Available for Power BI training, dashboard design, academic analytics and data-storytelling assignments.</h2>
      <a class="btn btn-gold" href={withBase('/contact')}>Discuss a data engagement</a>
    </div>
  </section>
</BaseLayout>
