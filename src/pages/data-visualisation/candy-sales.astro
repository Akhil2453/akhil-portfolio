---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { withBase } from '../../utils/url';
---

<BaseLayout
  title="Candy Sales Power BI Case Study — In Development | Akhil Arun Menon"
  description="Development status for an upcoming Power BI sales analytics case study covering sales performance, profitability, targets and geography."
  noindex
>
  <PageHero
    eyebrow="Power BI case study"
    title="Candy Sales Performance and Profitability"
    description="This dashboard case study is currently being developed and will be published during this week."
  />

  <section class="section-sm section-soft">
    <div class="container">
      <div class="notice">
        <strong>Under construction:</strong>
        The Power BI report, dashboard screenshots, analytical measures and
        final insights are currently being prepared. This page will be updated
        after the report has been validated.
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Planned scope</p>

      <h2>What the completed case study will demonstrate</h2>

      <div class="grid grid-3" style="margin-top:2rem">
        <article class="feature-card">
          <span class="tag">Page 01</span>
          <h3 style="margin-top:1rem">Executive Sales Overview</h3>
          <p>
            Revenue, orders, quantity, profit, monthly trends, regional
            contribution and executive-level indicators.
          </p>
        </article>

        <article class="feature-card">
          <span class="tag">Page 02</span>
          <h3 style="margin-top:1rem">
            Product Margin and Profitability
          </h3>
          <p>
            Product contribution, factory performance, margin comparison and
            low-profit exceptions.
          </p>
        </article>

        <article class="feature-card">
          <span class="tag">Page 03</span>
          <h3 style="margin-top:1rem">Target and Geography Analysis</h3>
          <p>
            Actual-versus-target performance, geographical patterns and
            operational context.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container">
      <p class="eyebrow">Publication checklist</p>

      <h2>Materials being prepared</h2>

      <div class="grid grid-4" style="margin-top:2rem">
        <article class="feature-card">
          <div class="icon">01</div>
          <h3>Data Preparation</h3>
          <p>
            Source review, quality checks and Power Query transformations.
          </p>
        </article>

        <article class="feature-card">
          <div class="icon">02</div>
          <h3>Data Model</h3>
          <p>
            Relationship design, date structure and calculation logic.
          </p>
        </article>

        <article class="feature-card">
          <div class="icon">03</div>
          <h3>Report Design</h3>
          <p>
            Dashboard pages, visual hierarchy, filters and navigation.
          </p>
        </article>

        <article class="feature-card">
          <div class="icon">04</div>
          <h3>Case-Study Narrative</h3>
          <p>
            Measures, findings, limitations and recommended actions.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <p class="eyebrow">Viewing format</p>

      <h2>The completed report will be showcased without a public embed</h2>

      <p class="lead">
        Since the report is being developed in Power BI Desktop, the website
        will present high-resolution dashboard images, model documentation,
        selected DAX measures and a structured analytical walkthrough.
      </p>

      <p>
        A recorded demonstration may also be added to show filters,
        drill-through and report navigation.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container cta-band">
      <p class="eyebrow">Portfolio update</p>

      <h2>
        The completed Candy Sales case study will be published here during
        this week.
      </h2>

      <div class="btn-row">
        <a
          class="btn btn-gold"
          href={withBase('/data-visualisation')}
        >
          Return to data visualisation
        </a>

        <a
          class="btn btn-outline"
          href={withBase('/contact')}
        >
          Discuss Power BI training
        </a>
      </div>
    </div>
  </section>
</BaseLayout>