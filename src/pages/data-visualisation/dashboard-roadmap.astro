---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { withBase } from '../../utils/url';
const ideas = [
  {n:'01', title:'HR Workforce Overview', area:'HR', data:'Employee master, department, role, joining date, status', pages:'Headcount, attrition, tenure, department mix', output:'Executive HR overview'},
  {n:'02', title:'Recruitment Funnel', area:'HR', data:'Applications, source, stage, role, dates, outcome', pages:'Funnel, time-to-hire, source quality, ageing', output:'Talent acquisition review'},
  {n:'03', title:'Sales Executive Dashboard', area:'Sales', data:'Orders, customers, products, regions, targets', pages:'Revenue, margin, trend, target variance', output:'Management sales review'},
  {n:'04', title:'Product Profitability Matrix', area:'Sales', data:'Products, units, price, cost, returns', pages:'Revenue versus margin, contribution, exceptions', output:'Portfolio decision view'},
  {n:'05', title:'Marketing Campaign Performance', area:'Marketing', data:'Campaign, channel, spend, leads, conversions', pages:'ROAS, CPL, conversion, channel comparison', output:'Campaign optimisation report'},
  {n:'06', title:'Social Media Content Analytics', area:'Marketing', data:'Posts, format, platform, reach, engagement, clicks', pages:'Content trend, format comparison, best posting windows', output:'Content planning dashboard'},
  {n:'07', title:'Student Performance Overview', area:'Academic', data:'Learner, course, assessments, marks, attendance', pages:'Achievement, risk, course comparison, learner drill-through', output:'Academic review dashboard'},
  {n:'08', title:'Course Readiness Tracker', area:'Academic', data:'Courses, units, faculty, assets, reviews, deadlines', pages:'Readiness, delays, ownership, dependency view', output:'Programme operations report'},
  {n:'09', title:'Faculty Workload and Delivery', area:'Academic', data:'Faculty, courses, hours, sessions, assessments, mentoring', pages:'Allocation, load balance, completion, variance', output:'Academic resource view'},
  {n:'10', title:'Workshop Impact Dashboard', area:'Academic / Training', data:'Participants, sessions, feedback, pre/post ratings, outputs', pages:'Participation, learning gain, feedback themes, outcomes', output:'Training impact report'}
];
---
<BaseLayout title="10 One-Day Dashboard Ideas | Akhil Arun Menon" description="A practical roadmap of 10 Power BI dashboards across HR, sales, marketing and academic analytics, each scoped for a focused one-day portfolio build.">
  <PageHero eyebrow="Portfolio build roadmap" title="Ten dashboards that can be built one at a time" description="Each idea is intentionally limited to a focused one-day build: clean one dataset, create a model, define essential measures and publish one decision-oriented report." />
  <section class="section">
    <div class="container">
      <div class="notice"><strong>One-day scope:</strong> use a prepared or simulated dataset, limit the report to one or two pages, and document the problem, measures, design decisions and three insights.</div>
      <div class="grid grid-2" style="margin-top:2rem">
        {ideas.map((idea) => (
          <article class="feature-card">
            <div class="icon">{idea.n}</div>
            <span class="tag">{idea.area}</span>
            <h3 style="margin-top:1rem">{idea.title}</h3>
            <p><strong>Data:</strong> {idea.data}</p>
            <p><strong>Report:</strong> {idea.pages}</p>
            <p><strong>Portfolio output:</strong> {idea.output}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
  <section class="section section-dark">
    <div class="container grid grid-3">
      <article class="feature-card"><h3>Morning</h3><p>Define the question, inspect the data, clean fields and build the relationship model.</p></article>
      <article class="feature-card"><h3>Afternoon</h3><p>Create core measures, build the page, configure interactions and validate calculations.</p></article>
      <article class="feature-card"><h3>Evening</h3><p>Write the case-study summary, capture screenshots, publish and add the entry to this website.</p></article>
    </div>
  </section>
  <section class="section"><div class="container cta-band"><h2>Start with the Sales Executive Dashboard, then alternate industries to show range.</h2><a class="btn btn-gold" href={withBase('/data-visualisation')}>Return to data visualisation</a></div></section>
</BaseLayout>
