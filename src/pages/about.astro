---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { withBase } from '../utils/url';
---
<BaseLayout title="About Akhil Arun Menon | Academic Programmes, EdTech, Robotics and Data" description="Professional profile of Akhil Arun Menon: Design Engineering educator, academic programme strategist, robotics mentor and data visualisation practitioner.">
  <PageHero eyebrow="About" title="An educator-engineer working across programmes, people, platforms and prototypes" description="Over a decade of work across higher education, EdTech, curriculum development, robotics, embedded systems, software and data visualisation." />

  <section class="section">
    <div class="container split">
      <div class="split-media"><img src={withBase('/images/profile/akhil-headshot.webp')} alt="Professional portrait of Akhil Arun Menon" /></div>
      <div>
        <p class="eyebrow">Professional narrative</p>
        <h2>Connecting academic intent with systems that can actually be delivered</h2>
        <p class="lead">My work is centred on converting ambitious educational ideas into curriculum, faculty practice, learning activities, technology systems and measurable operating processes.</p>
        <p>I have worked across university programmes, online and blended learning, K–12 maker education, robotics competitions, content engineering and programme operations. This range allows me to see a course not only as academic content, but as a complete learner experience supported by faculty, assessments, resources, platforms and evidence.</p>
        <p>My technical background in electronics, embedded systems, software and data helps me move comfortably between academic planning and implementation. I can discuss programme outcomes, build a project dashboard, review a robot mechanism, structure a faculty workshop or design a practical activity within the same broader objective: making learning more meaningful and executable.</p>
        <blockquote class="quote">Build the academic system around what learners should be able to observe, decide, create, test and explain.</blockquote>
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <p class="eyebrow">Capabilities</p>
      <h2>Areas where the work converges</h2>
      <div class="grid grid-3" style="margin-top:2rem">
        <article class="feature-card"><div class="icon">A</div><h3>Academic Architecture</h3><p>Programme design, syllabus structuring, course outcomes, lesson plans, activity frameworks and assessment systems.</p></article>
        <article class="feature-card"><div class="icon">E</div><h3>EdTech Operations</h3><p>Content engineering, online delivery, cross-functional production, quality assurance, LMS workflows and project tracking.</p></article>
        <article class="feature-card"><div class="icon">R</div><h3>Robotics & Making</h3><p>Competition mentoring, embedded systems, IoT, makerspaces, prototyping and technical capacity-building.</p></article>
        <article class="feature-card"><div class="icon">D</div><h3>Data & Visualisation</h3><p>Power BI, Excel, SQL and Python for programme monitoring, academic analytics and business dashboards.</p></article>
        <article class="feature-card"><div class="icon">F</div><h3>Faculty Development</h3><p>Teacher preparation for activity-based learning, AI-supported education, practical assessment and digital pedagogy.</p></article>
        <article class="feature-card"><div class="icon">S</div><h3>Software & Platforms</h3><p>Python, Django, React, Flutter and web technologies for academic tools, automation and learning applications.</p></article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Experience</p>
      <h2>Professional timeline</h2>
      <div class="timeline">
        <article class="timeline-item"><time>June 2026 – Present</time><h3>Assistant Professor — School of Design Engineering, REVA University</h3><p>Curriculum development, teacher preparation, activity-based lesson planning and hands-on assessment development for a new Design Engineering programme.</p></article>
        <article class="timeline-item"><time>November 2022 – Present</time><h3>Chief Academic & Programme Strategist — Phi-Grid Elite EdTech Pvt. Ltd.</h3><p>Academic content strategy, multidisciplinary programme design, cross-functional delivery, quality systems and programme analytics.</p></article>
        <article class="timeline-item"><time>November 2024 – May 2026</time><h3>Senior Programme Manager — The Innovation Story, Amazon Future Engineer Makerspace</h3><p>Makerspace operations, robotics mentoring, team coordination, competition preparation, workshops, safety and stakeholder reporting.</p></article>
        <article class="timeline-item"><time>July 2024 – November 2024</time><h3>Senior Manager — Content and Programme Strategy, Hyper Launch</h3><p>Programme development, content strategy, LMS management, SME and trainer coordination, quality assurance and stakeholder engagement.</p></article>
        <article class="timeline-item"><time>June 2022 – July 2024</time><h3>Associate Content Developer — UNext Learning Pvt. Ltd.</h3><p>End-to-end academic content management, technology-domain curriculum, programme dashboards, faculty coordination and online-learning delivery.</p></article>
        <article class="timeline-item"><time>August 2022 – Present</time><h3>Adjunct / Visiting Faculty — Higher Education Institutions</h3><p>Teaching across IoT, mobile application development, Python, Java, data scraping, unstructured data analysis and computing subjects.</p></article>
        <article class="timeline-item"><time>June 2023 – Present</time><h3>Freelance Trainer and Content Developer</h3><p>Professional training, data visualisation, automation, technology workshops and curriculum assignments.</p></article>
        <article class="timeline-item"><time>August 2022 – August 2023</time><h3>SME Consultant — Hurix Learning Pvt. Ltd.</h3><p>Technical content, video learning, full-stack curriculum, activity design and SME coordination.</p></article>
        <article class="timeline-item"><time>December 2019 – December 2022</time><h3>Assistant Professor — Jain (Deemed-to-be University) / iNurture Education Solutions</h3><p>Teaching, curriculum development, online content, project mentoring, faculty-development initiatives and academic documentation.</p></article>
        <article class="timeline-item"><time>August 2021 – August 2022</time><h3>Software Consultant — Linchpin Analytics Collaborative</h3><p>Python and JavaScript platform support, Django development, Git administration, technical documentation and developer onboarding.</p></article>
        <article class="timeline-item"><time>June 2021 – December 2021</time><h3>Tutor — SkillIT</h3><p>Online AI tutoring, course-content development and learner-orientation sessions.</p></article>
        <article class="timeline-item"><time>August 2019 – December 2019</time><h3>Research Associate — uFaber Education Pvt. Ltd.</h3><p>Robotics, coding and embedded-systems projects, one-to-one curriculum development and trainer preparation.</p></article>
        <article class="timeline-item"><time>June 2016 – April 2019</time><h3>Maker Coordinator — Consilience Learning</h3><p>Hands-on engineering curriculum, team coordination, quality assurance, trainer development and school implementation.</p></article>
      </div>
    </div>
  </section>

