---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, readingTime } from '../../utils/format';
import { withBase, absoluteUrl } from '../../utils/url';

export async function getStaticPaths() {
  const showDrafts = process.env.NODE_ENV !== 'production' || process.env.SHOW_DRAFTS === 'true';
  const posts = (await getCollection('blog')).filter((post) => showDrafts || !post.data.draft);
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
const pageUrl = absoluteUrl(`/blog/${post.id}`);
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  image: absoluteUrl(post.data.image),
  author: { '@type': 'Person', name: 'Akhil Arun Menon', url: absoluteUrl('/') },
  mainEntityOfPage: pageUrl
};
---
<BaseLayout title={`${post.data.title} | Akhil Arun Menon`} description={post.data.description} image={post.data.image} article jsonLd={articleSchema} noindex={post.data.draft}>
  <article>
    <header class="page-hero">
      <div class="narrow">
        {post.data.draft && <div class="notice" style="margin-bottom:1.5rem"><strong>Draft preview:</strong> this article is hidden from production builds unless SHOW_DRAFTS is enabled.</div>}
        <p class="eyebrow">{post.data.category}</p>
        <h1>{post.data.title}</h1>
        <p class="lead">{post.data.description}</p>
        <div class="card-meta"><time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time><span>{readingTime(post.body ?? '')} min read</span></div>
        <div class="tag-list">{post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}</div>
      </div>
    </header>
    <div class="narrow" style="margin-top:-2rem;position:relative;z-index:2"><div class="project-cover"><img src={withBase(post.data.image)} alt={post.data.imageAlt} /></div></div>
    <section class="section"><div class="narrow prose"><Content /></div></section>
  </article>

  {post.data.downloadableResource && (
    <section class="section-sm section-soft"><div class="narrow"><div class="notice"><strong>Downloadable resource:</strong> <a href={withBase(post.data.downloadableResource)} download>Download the companion checklist</a>.</div></div></section>
  )}

  <section class="section-sm">
    <div class="narrow">
      <p class="eyebrow">Share</p>
      <div class="btn-row">
        <a class="btn btn-outline" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener">Share on LinkedIn</a>
        <a class="btn btn-outline" href={`mailto:?subject=${encodeURIComponent(post.data.title)}&body=${encodeURIComponent(pageUrl)}`}>Share by email</a>
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="narrow">
      <p class="eyebrow">Discussion</p>
      <h2>Comments</h2>
      <p class="text-muted">Comments use GitHub Issues through Utterances. The repository must be public and the Utterances app must be installed once.</p>
      <div class="comments" data-comments></div>
      <script is:inline>
        (() => {
          const container = document.querySelector('[data-comments]');
          if (!container) return;
          const script = document.createElement('script');
          script.src = 'https://utteranc.es/client.js';
          script.async = true;
          script.crossOrigin = 'anonymous';
          script.setAttribute('repo', 'Akhil2453/akhil-portfolio');
          script.setAttribute('issue-term', 'pathname');
          script.setAttribute('label', 'blog-comment');
          script.setAttribute('theme', 'preferred-color-scheme');
          container.appendChild(script);
        })();
      </script>
    </div>
  </section>

  <section class="section"><div class="container cta-band"><h2>Explore more articles or discuss an academic, technology or data engagement.</h2><div class="btn-row"><a class="btn btn-gold" href={withBase('/blog')}>Back to blog</a><a class="btn btn-outline" href={withBase('/contact')}>Contact Akhil</a></div></div></section>
</BaseLayout>
